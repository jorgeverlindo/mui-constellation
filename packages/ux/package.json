{
  "name": "@jorgeverlindo/constellation-ux",
  "version": "0.1.0",
  "description": "Constellation Design System — MUI component library and theme (AV3 Constellation DS)",
  "license": "UNLICENSED",
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./date-picker": {
      "types": "./dist/date-picker.d.ts",
      "import": "./dist/date-picker.js",
      "require": "./dist/date-picker.cjs"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build"
  },
  "publishConfig": {
    "registry": "https://npm.pkg.github.com",
    "access": "restricted"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/jorgeverlindo/constellation-ux.git"
  },
  "peerDependencies": {
    "@emotion/react": "^11.0.0",
    "@emotion/styled": "^11.0.0",
    "@mui/icons-material": "^7.0.0",
    "@mui/material": "^7.0.0",
    "@mui/x-date-pickers": "^8.0.0",
    "date-fns": "^3.0.0 || ^4.0.0",
    "react": ">=18",
    "react-dom": ">=18"
  },
  "peerDependenciesMeta": {
    "@mui/icons-material": { "optional": true },
    "@mui/x-date-pickers": { "optional": true },
    "date-fns": { "optional": true }
  },
  "devDependencies": {
    "@emotion/react": "^11.14.0",
    "@emotion/styled": "^11.14.0",
    "@fontsource/inter": "^5.2.8",
    "@mui/icons-material": "^7.3.11",
    "@mui/material": "^7.1.0",
    "@mui/x-date-pickers": "^8.29.0",
    "@storybook/react-vite": "^9.1.20",
    "@types/react": "^19.1.0",
    "@types/react-dom": "^19.1.0",
    "date-fns": "^3.6.0",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "storybook": "^9.1.20",
    "tsup": "^8.4.0",
    "typescript": "^5.8.0",
    "vite": "^6.4.3"
  }
}
